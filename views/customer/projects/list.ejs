<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL',
  title: 'Projects',
  subtitle: 'The engagements DB Studio is delivering for your company.'
}) %>

<% if (projects && projects.length) { %>
  <div class="project-grid">
    <% projects.forEach(function(p) { %>
      <a class="card card--link" href="/customer/projects/<%= p.id %>">
        <p class="card__eyebrow eyebrow"><%= p.status %></p>
        <h2 class="card__title"><%= p.name %></h2>
        <% if (p.objeto_proyecto) { %>
          <p class="card__subtitle"><%= p.objeto_proyecto %></p>
        <% } %>
        <p class="card__count">
          <span class="card__count-meta">Created <%= euDate(p.created_at) %></span>
        </p>
      </a>
    <% }) %>
  </div>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No projects yet',
    lead: 'When DB Studio kicks off work for your company, each engagement appears here with its scope and current status.',
    secondaryHref: '/customer/dashboard',
    secondaryLabel: 'Back to dashboard'
  }) %>
<% } %>
