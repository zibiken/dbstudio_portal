<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL · PROFILE',
  title: 'Confirm new email address'
}) %>

<div class="card">
  <p>You're about to change the email on your DB Studio portal account to the address you used to open this link.</p>
  <p class="card__subtitle">After confirming, a notification with a one-week revert link will be sent to the previous address.</p>
  <% if (typeof error !== 'undefined' && error) { %>
    <%- include('../../components/_alert', { variant: 'error', body: error }) %>
  <% } %>
  <form method="post" action="/customer/profile/email/verify/<%= token %>" class="form-stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-actions">
      <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Confirm change' }) %>
      <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/customer/profile', label: 'Cancel' }) %>
    </div>
  </form>
</div>
