<section class="customer-profile">
  <header class="customer-section-header">
    <h1>Confirm new email address</h1>
  </header>

  <article class="customer-card">
    <p>You're about to change the email on your DB Studio portal account to the address you used to open this link.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="form-error" role="alert"><%= error %></p>
    <% } %>
    <form method="post" action="/customer/profile/email/verify/<%= token %>" class="customer-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <p class="muted">After confirming, a notification with a one-week revert link will be sent to the previous address.</p>
      <button type="submit">Confirm change</button>
      <a href="/customer/profile" class="cancel-link">Cancel</a>
    </form>
  </article>
</section>
