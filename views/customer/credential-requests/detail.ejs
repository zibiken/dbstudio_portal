<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL · CREDENTIAL REQUESTS',
  title: request.provider,
  subtitle: 'DB Studio is asking for the values listed below.'
}) %>

<%
  var pillKey = request.status === 'open' ? 'pending' :
                request.status === 'fulfilled' ? 'fulfilled' :
                request.status === 'cancelled' ? 'archived' :
                request.status === 'not_applicable' ? 'void' : 'pending';
  var f = (typeof form !== 'undefined' && form) ? form : {};
%>

<div class="detail-status-strip">
  <span class="detail-status-strip__label">Status</span>
  <span class="status-pill status-pill--<%= pillKey %>"><%= request.status %></span>
  <a class="btn btn--ghost btn--sm detail-status-strip__edit" href="/customer/credential-requests">Back to requests</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<div class="card">
  <h2 class="card__title">Details</h2>
  <dl class="kv">
    <dt>Status</dt><dd><%= request.status %></dd>
    <dt>Created</dt><dd><%= euDateTime(request.created_at) %></dd>
    <dt>Updated</dt><dd><%= euDateTime(request.updated_at) %></dd>
    <% if (request.status === 'not_applicable' && request.not_applicable_reason) { %>
      <dt>Your reason</dt><dd><%= request.not_applicable_reason %></dd>
    <% } %>
  </dl>
</div>

<% if (request.status === 'open') { %>
  <div class="card">
    <h2 class="card__title">Provide credentials</h2>
    <p class="card__subtitle">Values you enter here are encrypted with your account vault key before they are saved. Anything marked <strong>secret</strong> is masked when displayed back.</p>

    <form method="post" action="/customer/credential-requests/<%= request.id %>/fulfil" autocomplete="off" class="form-stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="input-field">
        <label class="input-field__label" for="cred_label">Label</label>
        <div class="input-field__control">
          <input id="cred_label" type="text" name="label" maxlength="200"
                 placeholder="<%= request.provider %>"
                 value="<%= f.label ?? '' %>">
        </div>
        <p class="input-field__helper">Optional. Defaults to the provider name.</p>
      </div>

      <% request.fields.forEach(function(field) { %>
        <div class="input-field">
          <label class="input-field__label" for="cred_field_<%= field.name %>"><%= field.label %><%= field.required ? ' *' : '' %></label>
          <div class="input-field__control">
            <% if (field.type === 'note') { %>
              <textarea id="cred_field_<%= field.name %>" name="field__<%= field.name %>" rows="4" <%= field.required ? 'required' : '' %>><%= (f.payload && f.payload[field.name]) || '' %></textarea>
            <% } else if (field.type === 'secret') { %>
              <input id="cred_field_<%= field.name %>" type="password" name="field__<%= field.name %>" <%= field.required ? 'required' : '' %>
                     autocomplete="new-password" value="<%= (f.payload && f.payload[field.name]) || '' %>">
            <% } else if (field.type === 'url') { %>
              <input id="cred_field_<%= field.name %>" type="url" name="field__<%= field.name %>" <%= field.required ? 'required' : '' %>
                     value="<%= (f.payload && f.payload[field.name]) || '' %>">
            <% } else { %>
              <input id="cred_field_<%= field.name %>" type="text" name="field__<%= field.name %>" <%= field.required ? 'required' : '' %>
                     value="<%= (f.payload && f.payload[field.name]) || '' %>">
            <% } %>
          </div>
        </div>
      <% }) %>

      <div class="form-actions">
        <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Save credentials' }) %>
      </div>
    </form>
  </div>

  <div class="card">
    <h2 class="card__title">Or mark as not applicable</h2>
    <p class="card__subtitle">If this provider does not apply to you, tell us briefly why and we'll close the request.</p>
    <form method="post" action="/customer/credential-requests/<%= request.id %>/not-applicable" class="form-stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="input-field">
        <label class="input-field__label" for="cred_reason">Reason</label>
        <div class="input-field__control">
          <textarea id="cred_reason" name="reason" rows="3" required maxlength="2000"><%= f.reason ?? '' %></textarea>
        </div>
      </div>
      <div class="form-actions">
        <%- include('../../components/_button', { variant: 'secondary', size: 'md', type: 'submit', label: 'Mark not applicable' }) %>
      </div>
    </form>
  </div>
<% } else if (request.status === 'fulfilled') { %>
  <div class="card">
    <p>Thank you — these credentials are saved and visible to DB Studio.</p>
  </div>
<% } else if (request.status === 'cancelled') { %>
  <div class="card">
    <p class="muted">This request was cancelled by DB Studio. No action needed.</p>
  </div>
<% } %>
