<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL',
  title: 'NDAs',
  subtitle: 'Non-disclosure agreements between you and DB Studio.'
}) %>

<% if (rows && rows.length) { %>
  <div class="table-wrap">
    <table class="data-table data-table--medium">
      <thead>
        <tr>
          <th scope="col" class="data-table__th data-table__th--left">Project</th>
          <th scope="col" class="data-table__th data-table__th--left">Generated</th>
          <th scope="col" class="data-table__th data-table__th--left">Template</th>
          <th scope="col" class="data-table__th data-table__th--left">Signed PDF</th>
          <th scope="col" class="data-table__th data-table__th--left">Audit trail</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(r) { %>
          <tr>
            <td class="data-table__td data-table__td--left"><%= r.project_name %></td>
            <td class="data-table__td data-table__td--left"><time datetime="<%= new Date(r.generated_at).toISOString() %>"><%= euDate(r.generated_at) %></time></td>
            <td class="data-table__td data-table__td--left"><code class="muted"><%= (r.template_version_sha || '').slice(0, 8) %></code></td>
            <td class="data-table__td data-table__td--left">
              <% if (r.signed_document_id) { %>
                <a class="btn btn--ghost btn--sm" href="/customer/documents/<%= r.signed_document_id %>/download">Download →</a>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>
            <td class="data-table__td data-table__td--left">
              <% if (r.audit_document_id) { %>
                <a class="btn btn--ghost btn--sm" href="/customer/documents/<%= r.audit_document_id %>/download">Download →</a>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No NDAs yet',
    lead: 'Once you sign an NDA with DB Studio, the signed copy and the audit trail from the signing platform appear here for download.',
    secondaryHref: '/customer/dashboard',
    secondaryLabel: 'Back to dashboard'
  }) %>
<% } %>
