<section class="customer-dashboard">
  <header class="customer-section-header">
    <h1>Hello, <%= user.name %></h1>
    <p class="subtitle"><%= customer.razon_social %></p>
  </header>

  <div class="customer-grid">
    <article class="customer-card">
      <h2>Documents</h2>
      <p>Project documents and signed agreements.</p>
      <p><a href="/customer/documents">Open documents →</a></p>
    </article>

    <article class="customer-card">
      <h2>Projects</h2>
      <p>Active and archived engagements.</p>
      <p><a href="/customer/projects">Open projects →</a></p>
    </article>

    <article class="customer-card">
      <h2>Invoices</h2>
      <p>Open, paid, and overdue invoices.</p>
      <p><a href="/customer/invoices">Open invoices →</a></p>
    </article>

    <article class="customer-card">
      <h2>NDAs</h2>
      <p>Signed non-disclosure agreements.</p>
      <p><a href="/customer/ndas">Open NDAs →</a></p>
    </article>

    <article class="customer-card">
      <h2>Credentials</h2>
      <p>Production logins, API keys, and shared secrets — vaulted under your customer key.</p>
      <p><a href="/customer/credentials">Open credential vault →</a></p>
      <p><a href="/customer/credential-requests">Open credential requests →</a></p>
    </article>

    <article class="customer-card">
      <h2>Profile</h2>
      <dl class="customer-fields">
        <dt>Name</dt><dd><%= user.name %></dd>
        <dt>Email</dt><dd><%= user.email %></dd>
        <dt>Company</dt><dd><%= customer.razon_social %></dd>
      </dl>
      <p><a href="/customer/profile">Edit profile →</a></p>
      <p><a href="/customer/activity">View account activity →</a></p>
    </article>
  </div>
</section>
