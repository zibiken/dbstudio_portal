<%- include('../components/_page-header', {
  eyebrow: customer.razon_social,
  title: 'Hello, ' + user.name,
  subtitle: 'Your projects, NDAs, credentials and invoices in one place.'
}) %>

<% if (typeof cleanupBanner !== 'undefined' && cleanupBanner) { %>
  <div class="cleanup-banner">
    <div class="cleanup-banner__body">
      DB Studio cleaned up your <code><%= cleanupBanner.provider %></code> credential on
      <time datetime="<%= cleanupBanner.ts.toISOString() %>"><%= euDate(cleanupBanner.ts) %></time>.
    </div>
    <form method="post" action="/customer/dashboard/cleanup-banner/dismiss" class="cleanup-banner__dismiss">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" aria-label="Dismiss">×</button>
    </form>
  </div>
<% } %>

<% if (openQuestions && openQuestions.length > 0) { %>
  <div class="card card--action">
    <h2 class="card__title">Questions for you</h2>
    <p class="card__subtitle">DB Studio is waiting on a short answer from you.</p>
    <ul class="customer-questions customer-questions--dashboard">
      <% openQuestions.forEach(function(q) { %>
        <li class="customer-questions__item customer-questions__item--open">
          <a href="/customer/questions/<%= q.id %>" class="customer-questions__link">
            <%= q.question.length > 120 ? q.question.slice(0, 120) + '…' : q.question %>
          </a>
        </li>
      <% }) %>
    </ul>
  </div>
<% } %>

<%
  function fmtLatest(latestAt) {
    if (!latestAt) return null;
    return euDateTime(latestAt);
  }
%>

<div class="bento">
  <%- include('../components/_card', {
    eyebrow: 'NDAs',
    title:   'Agreements',
    count:   summary.ndas.count,
    latestAt: fmtLatest(summary.ndas.latestAt),
    unread:   summary.ndas.unreadCount,
    body:    summary.ndas.unreadCount > 0
      ? '<p class="muted">' + summary.ndas.unreadCount + ' awaiting your signature.</p>'
      : '<p class="muted">Signed and historical NDAs on file.</p>',
    footerHref:  '/customer/ndas',
    footerLabel: 'Open NDAs →'
  }) %>

  <%- include('../components/_card', {
    eyebrow: 'Documents',
    title:   'Files',
    count:   summary.documents.count,
    latestAt: fmtLatest(summary.documents.latestAt),
    body:    '<p class="muted">Project deliverables and other shared files.</p>',
    footerHref:  '/customer/documents',
    footerLabel: 'Open documents →'
  }) %>

  <%- include('../components/_card', {
    eyebrow: 'Credentials',
    title:   'Vault',
    count:   summary.credentials.count,
    latestAt: fmtLatest(summary.credentials.latestAt),
    unread:   summary.credentials.unreadCount,
    body:    summary.credentials.unreadCount > 0
      ? '<p class="muted">' + summary.credentials.unreadCount + ' flagged for refresh.</p>'
      : '<p class="muted">Encrypted with your account vault key. Every admin read is recorded in your activity log.</p>',
    footerHref:  '/customer/credentials',
    footerLabel: 'Open vault →'
  }) %>

  <%- include('../components/_card', {
    eyebrow: 'Credential requests',
    title:   'To share',
    count:   summary.credentialRequests.count,
    latestAt: fmtLatest(summary.credentialRequests.latestAt),
    unread:   summary.credentialRequests.unreadCount,
    body:    summary.credentialRequests.unreadCount > 0
      ? '<p class="muted">' + summary.credentialRequests.unreadCount + ' open ' + (summary.credentialRequests.unreadCount === 1 ? 'request' : 'requests') + ' waiting on you.</p>'
      : '<p class="muted">Provider-by-provider asks from your studio.</p>',
    footerHref:  '/customer/credential-requests',
    footerLabel: 'Open requests →'
  }) %>

  <%- include('../components/_card', {
    eyebrow: 'Invoices',
    title:   'Billing',
    count:   summary.invoices.count,
    latestAt: fmtLatest(summary.invoices.latestAt),
    unread:   summary.invoices.unreadCount,
    body:    summary.invoices.unreadCount > 0
      ? '<p class="muted">' + summary.invoices.unreadCount + ' open ' + (summary.invoices.unreadCount === 1 ? 'invoice' : 'invoices') + '.</p>'
      : '<p class="muted">All current and historical invoices.</p>',
    footerHref:  '/customer/invoices',
    footerLabel: 'Open invoices →'
  }) %>

  <%- include('../components/_card', {
    eyebrow: 'Projects',
    title:   'Engagements',
    count:   summary.projects.count,
    latestAt: fmtLatest(summary.projects.latestAt),
    body:    '<p class="muted">Scope, timeline, and status of every active engagement.</p>',
    footerHref:  '/customer/projects',
    footerLabel: 'Open projects →'
  }) %>
</div>

<section class="dashboard-meta">
  <div class="card">
    <p class="card__eyebrow eyebrow">Signed in as</p>
    <h2 class="card__title"><%= user.name %></h2>
    <p class="card__subtitle"><%= user.email %> · <%= customer.razon_social %></p>
    <div class="form-actions">
      <%- include('../components/_button', { variant: 'secondary', size: 'sm', href: '/customer/profile', label: 'Edit profile' }) %>
      <%- include('../components/_button', { variant: 'ghost',     size: 'sm', href: '/customer/activity', label: 'View activity' }) %>
    </div>
  </div>
</section>
