<section class="customer-credentials">
  <header class="customer-section-header">
    <h1>Add a credential</h1>
    <p class="subtitle">The values you enter are encrypted under your customer key
      before they leave the request.</p>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <article class="customer-card">
    <form method="post" action="/customer/credentials" class="customer-form" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="cred-provider">Provider</label>
      <input id="cred-provider" name="provider" type="text" required maxlength="128"
             value="<%= form && form.provider ? form.provider : '' %>"
             placeholder="e.g. AWS, GitHub, Stripe">

      <label for="cred-label">Label</label>
      <input id="cred-label" name="label" type="text" required maxlength="128"
             value="<%= form && form.label ? form.label : '' %>"
             placeholder="What this credential is for">

      <fieldset>
        <legend>Fields</legend>
        <p class="muted">At least one field is required. Add as many name/value pairs as you need.
          Values are masked while typing and are <strong>not echoed back</strong> on a validation
          error — re-type them if the form re-renders.</p>
        <% // Re-render the field NAMES on validation error so the user doesn't
           // have to retype field names — but NEVER re-render the values:
           // echoing a secret back into the rendered HTML is a privacy
           // regression (browser autofill capture, screenshare reveal, back-
           // forward cache). M9 review I2 / M2.
           const formPayload = (form && form.payload) || {};
           const keys = Object.keys(formPayload);
           const rows = keys.length > 0 ? keys.length : 3; %>
        <input type="hidden" name="field_count" value="<%= rows %>">
        <% for (let i = 0; i < rows; i++) {
             const k = keys[i] ?? '';
        %>
          <div class="customer-form-row">
            <input type="text" name="field_name_<%= i %>" placeholder="field name" aria-label="field name <%= i + 1 %>" value="<%= k %>" maxlength="64">
            <input type="password" name="field_value_<%= i %>" placeholder="value" aria-label="value for field <%= i + 1 %>" maxlength="2048" autocomplete="off">
          </div>
        <% } %>
      </fieldset>

      <button type="submit">Save credential</button>
      <a href="/customer/credentials" class="cancel-link">Cancel</a>
    </form>
  </article>
</section>
