<%- include('../../components/_page-header', {
  eyebrow: 'CUSTOMER · CREDENTIALS',
  title: 'Edit credential',
  subtitle: credential.provider + ' · ' + credential.label
}) %>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<form method="post" action="/customer/credentials/<%= credential.id %>/edit" class="form-stack" autocomplete="new-password">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="card">
    <h2 class="card__title">Label</h2>
    <p class="card__subtitle">A short name so you can find this credential later. Provider stays as <strong><%= credential.provider %></strong> — to change the provider, delete and re-add.</p>
    <%- include('../../components/_input', {
      name: 'label', type: 'text', label: 'Label',
      required: true, maxlength: 128,
      value: form && form.label ? form.label : credential.label,
      placeholder: 'What this credential is for'
    }) %>
  </div>

  <div class="card">
    <h2 class="card__title">Rotate secret (optional)</h2>
    <p class="card__subtitle">Type the new field name + value pairs below to <strong>overwrite</strong> the stored secret. Leave every row empty to keep the current secret unchanged. Old values are not echoed back; we never decrypt without your action.</p>
    <%
      const formPayload = (form && form.payload) || {};
      const keys = Object.keys(formPayload);
      const rows = keys.length > 0 ? keys.length : 3;
    %>
    <input type="hidden" name="field_count" value="<%= rows %>">
    <div class="form-stack">
      <% for (let i = 0; i < rows; i++) {
           const k = keys[i] ?? '';
      %>
        <div class="customer-cred-row">
          <input class="cr-fields__input" type="text" name="field_name_<%= i %>" placeholder="field name" aria-label="field name <%= i + 1 %>" value="<%= k %>" maxlength="64">
          <input id="cred_edit_field_value_<%= i %>" class="cr-fields__input" type="password" name="field_value_<%= i %>" placeholder="value" aria-label="value for field <%= i + 1 %>" maxlength="2048" autocomplete="new-password">
          <button type="button" class="input-field__toggle" data-input="cred_edit_field_value_<%= i %>" aria-label="Show password" aria-pressed="false">
            <svg class="input-field__toggle-icon input-field__toggle-icon--show" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="input-field__toggle-icon input-field__toggle-icon--hide" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" hidden><path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-7 0-11-7-11-7a19.79 19.79 0 0 1 4.22-5.94"/><path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 7 11 7a19.79 19.79 0 0 1-3.17 4.31"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      <% } %>
    </div>
  </div>

  <div class="form-actions">
    <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Save changes' }) %>
    <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/customer/credentials/' + credential.id, label: 'Cancel' }) %>
  </div>
</form>
