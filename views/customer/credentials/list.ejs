<section class="customer-credentials">
  <header class="customer-section-header">
    <h1>Credentials</h1>
    <p class="subtitle">Production logins, API keys, and shared secrets stored against
      your account. Values are encrypted under your customer key and only revealed
      after a re-authenticated request.</p>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <article class="customer-card">
    <p><a href="/customer/credentials/new" class="cta-link">Add a credential</a></p>
  </article>

  <article class="customer-card">
    <% if (!credentials.length) { %>
      <p class="muted">You have no credentials stored yet.</p>
    <% } else { %>
      <table class="customer-table">
        <thead>
          <tr>
            <th scope="col">Provider</th>
            <th scope="col">Label</th>
            <th scope="col">Stored by</th>
            <th scope="col">Added</th>
            <th scope="col">Updated</th>
            <th scope="col">Status</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody>
          <% credentials.forEach(function (c) { %>
            <tr>
              <td><%= c.provider %></td>
              <td><%= c.label %></td>
              <td><%= c.created_by %></td>
              <td><%= euDate(c.created_at) %></td>
              <td><%= euDate(c.updated_at) %></td>
              <td>
                <% if (c.needs_update) { %>
                  <span class="badge-warn">Needs update</span>
                <% } else { %>
                  <span class="muted">stored</span>
                <% } %>
              </td>
              <td>
                <form method="post" action="/customer/credentials/<%= encodeURIComponent(c.id) %>/delete"
                      onsubmit="return confirm('Delete this credential?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="link-button">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    <p class="muted">Viewing the stored values is operator-side: ask DB Studio
      via a credential request, every view leaves an audit entry visible to you
      under <a href="/customer/activity?filter=credentials">Activity</a>.</p>
  </article>
</section>
