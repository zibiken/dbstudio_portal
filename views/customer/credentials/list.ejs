<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL',
  title: 'Credentials',
  subtitle: 'Logins, API keys, and shared secrets stored against your account.'
}) %>

<%- include('../../components/_alert', {
  variant: 'info',
  body: 'Values are encrypted under your account vault key. DB Studio admins can decrypt them when actively viewing — every view leaves a record in your <a href="/customer/activity?filter=credentials">Activity</a> feed. You can also view them yourself with a re-2FA confirmation by clicking a credential\'s label.'
}) %>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<%- include('../../components/_list-toolbar', {
  action: '/customer/credentials',
  q: '',
  total: credentials.length,
  totalLabel: 'credential',
  placeholder: 'Search credentials…',
  ctaHref: '/customer/credentials/new',
  ctaLabel: 'Add a credential'
}) %>

<% if (credentials && credentials.length) { %>
  <%
    const projectList = (typeof projects !== 'undefined' && Array.isArray(projects)) ? projects : [];
    const projectById = new Map(projectList.map(function(p) { return [p.id, p]; }));
    const groups = new Map();
    groups.set(null, { id: null, name: 'Company-wide', credentials: [] });
    credentials.forEach(function(c) {
      const key = c.project_id || null;
      if (!groups.has(key)) {
        const proj = projectById.get(key);
        groups.set(key, { id: key, name: proj ? proj.name : 'Unknown project', credentials: [] });
      }
      groups.get(key).credentials.push(c);
    });
    // Drop the company-wide bucket if empty so the page doesn't lead with an empty heading.
    if (groups.get(null).credentials.length === 0) groups.delete(null);
    const orderedGroups = Array.from(groups.values());
  %>
  <% orderedGroups.forEach(function(group) { %>
    <h2 class="cred-group__heading"><%= group.name %> <span class="cred-group__count">· <%= group.credentials.length %></span></h2>
    <div class="table-wrap">
      <table class="data-table data-table--medium">
        <thead>
          <tr>
            <th scope="col" class="data-table__th data-table__th--left">Provider</th>
            <th scope="col" class="data-table__th data-table__th--left">Label</th>
            <th scope="col" class="data-table__th data-table__th--left">Origin</th>
            <th scope="col" class="data-table__th data-table__th--left">Freshness</th>
            <th scope="col" class="data-table__th data-table__th--left">Updated</th>
            <th scope="col" class="data-table__th data-table__th--right"></th>
          </tr>
        </thead>
        <tbody>
          <% group.credentials.forEach(function(c) { %>
            <tr>
              <td class="data-table__td data-table__td--left"><%= c.provider %></td>
              <td class="data-table__td data-table__td--left"><a href="/customer/credentials/<%= encodeURIComponent(c.id) %>"><%= c.label %></a></td>
              <td class="data-table__td data-table__td--left">
                <span class="status-pill status-pill--<%= c.created_by === 'admin' ? 'pending' : 'active' %>">
                  <%= c.created_by === 'admin' ? 'created by DB Studio' : 'added by you' %>
                </span>
              </td>
              <td class="data-table__td data-table__td--left">
                <% if (c.needs_update) { %>
                  <span class="status-pill status-pill--overdue">needs update</span>
                <% } else { %>
                  <span class="status-pill status-pill--paid">current</span>
                <% } %>
              </td>
              <td class="data-table__td data-table__td--left"><time datetime="<%= new Date(c.updated_at).toISOString() %>"><%= euDateTime(c.updated_at) %></time></td>
              <td class="data-table__td data-table__td--right">
                <form method="post" action="/customer/credentials/<%= encodeURIComponent(c.id) %>/delete"
                      class="form-inline-action"
                      onsubmit="return confirm('Delete this credential?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <%- include('../../components/_button', { variant: 'ghost', size: 'sm', type: 'submit', label: 'Delete' }) %>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% }) %>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No credentials yet',
    lead: 'Add a credential when you want DB Studio to be able to operate something on your behalf — staging environment access, an API key for a service we manage for you, etc. Values are encrypted under your account vault key before they leave the form.',
    ctaHref: '/customer/credentials/new',
    ctaLabel: 'Add the first credential'
  }) %>
<% } %>
