<section class="customer-profile-review">
  <h1>Confirm your profile</h1>
  <p>Make sure everything looks right. You can update these details later from your profile page.</p>

  <dl class="customer-fields">
    <dt>Your name</dt><dd><%= user.name %></dd>
    <dt>Your email</dt><dd><%= user.email %></dd>
    <dt>Company</dt><dd><%= customer.razon_social %></dd>
    <% if (customer.nif) { %><dt>NIF</dt><dd><%= customer.nif %></dd><% } %>
    <% if (customer.domicilio) { %><dt>Domicilio</dt><dd><%= customer.domicilio %></dd><% } %>
  </dl>

  <form method="post" action="/customer/welcome/profile">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit">Continue to my dashboard →</button>
  </form>
</section>
