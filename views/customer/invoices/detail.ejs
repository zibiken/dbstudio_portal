<%- include('../../components/_page-header', {
  eyebrow: 'PORTAL · INVOICES',
  title: 'Invoice ' + row.invoice_number,
  subtitle: (Number(row.amount_cents) / 100).toFixed(2) + ' ' + row.currency
}) %>

<%
  var statusKey = row.overdue && row.status === 'open' ? 'overdue' : row.status;
  var statusLabel = row.overdue && row.status === 'open' ? 'overdue' : row.status;
%>

<div class="detail-status-strip">
  <span class="detail-status-strip__label">Status</span>
  <span class="status-pill status-pill--<%= statusKey %>"><%= statusLabel %></span>
  <a class="btn btn--secondary btn--sm detail-status-strip__edit" href="/customer/documents/<%= row.document_id %>/download">Download PDF</a>
</div>

<div class="card">
  <h2 class="card__title">Details</h2>
  <dl class="kv">
    <dt>Number</dt> <dd><%= row.invoice_number %></dd>
    <dt>Amount</dt> <dd><%= (Number(row.amount_cents) / 100).toFixed(2) %> <%= row.currency %></dd>
    <dt>Issued</dt> <dd><%= euDate(row.issued_on) %></dd>
    <dt>Due</dt>    <dd><%= euDate(row.due_on) %></dd>
    <dt>Status</dt> <dd><%= row.status %><% if (row.overdue && row.status === 'open') { %> <span class="muted">— overdue</span><% } %></dd>
    <% if (row.notes) { %><dt>Notes</dt><dd><%= row.notes %></dd><% } %>
  </dl>
</div>

<div class="card">
  <h2 class="card__title">Payments</h2>
  <% if (payments && payments.length) { %>
    <ul style="list-style: none; padding-left: 0; margin: 0 0 12px;">
      <% payments.forEach(function(p) { %>
        <li style="padding: 6px 0; border-bottom: 1px solid var(--border-light);">
          <strong>€<%= (Number(p.amount_cents)/100).toFixed(2) %></strong>
          on <%= euDate(p.paid_on) %>
          <% if (p.note) { %><span class="muted"> — <%= p.note %></span><% } %>
        </li>
      <% }) %>
    </ul>
    <p>
      Paid <strong>€<%= (Number(paidCents)/100).toFixed(2) %></strong>
      of €<%= (Number(row.amount_cents)/100).toFixed(2) %>
      <% if (Number(paidCents) < Number(row.amount_cents)) { %>
        &middot; <span class="muted">outstanding €<%= ((Number(row.amount_cents) - Number(paidCents))/100).toFixed(2) %></span>
      <% } %>
    </p>
  <% } else { %>
    <p class="muted">No payments recorded yet.</p>
  <% } %>
</div>

<div class="form-actions">
  <%- include('../../components/_button', { variant: 'ghost', size: 'md', href: '/customer/invoices', label: 'Back to invoices' }) %>
</div>
