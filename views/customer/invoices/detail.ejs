<section class="customer-invoice-detail">
  <header class="customer-section-header">
    <h1>Invoice <%= row.invoice_number %></h1>
    <a class="btn btn-secondary" href="/customer/invoices">Back</a>
  </header>

  <table class="meta-table">
    <tr><th>Amount</th><td><%= (Number(row.amount_cents)/100).toFixed(2) %> <%= row.currency %></td></tr>
    <tr><th>Issued</th><td><%= euDate(row.issued_on) %></td></tr>
    <tr><th>Due</th><td><%= euDate(row.due_on) %><% if (row.overdue) { %> <span class="badge badge-warning">overdue</span><% } %></td></tr>
    <tr><th>Status</th><td><%= row.status %></td></tr>
    <% if (row.notes) { %><tr><th>Notes</th><td><%= row.notes %></td></tr><% } %>
    <tr><th>PDF</th><td><a href="/customer/documents/<%= row.document_id %>/download">Download invoice PDF</a></td></tr>
  </table>
</section>
