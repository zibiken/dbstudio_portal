<%# Password input with eye toggle, live rule compliance, and strength meter.
    Wraps _input with showHideToggle and adds the meter UI underneath.

    Locals:
      name        (required) input name (e.g. 'password' or 'new_password')
      label       (required) field label
      autocomplete  default: 'new-password'
      required      default: true
      minlength     default: 12 (matches domain PASSWORD_MIN_LENGTH)
      autofocus     default: false
      helper        optional helper text (rendered by _input)
      error         optional error string (rendered by _input)
      withConfirm   default: false. When true, renders a second
                    input named "<name>_confirm" and a live equality
                    indicator. Form submit blocks until match.
      confirmLabel  default: "Confirm password". Label for the second
                    input when withConfirm is true.
      nonce         (required from layout) CSP nonce for the inline meter script
%>
<%
  var pw_min = (typeof minlength !== 'undefined' && minlength !== null) ? minlength : 12;
  var pw_required = (typeof required !== 'undefined') ? required : true;
  var pw_autocomplete = (typeof autocomplete !== 'undefined' && autocomplete) ? autocomplete : 'new-password';
  var pw_autofocus = (typeof autofocus !== 'undefined') && autofocus;
  var pw_with_confirm = (typeof withConfirm !== 'undefined') && withConfirm;
  var pw_confirm_label = (typeof confirmLabel !== 'undefined' && confirmLabel) ? confirmLabel : 'Confirm password';
%>
<div class="password-field" data-password-field data-min-length="<%= pw_min %>" data-with-confirm="<%= pw_with_confirm ? 'true' : 'false' %>">
  <%- include('./_input', {
    name: name,
    type: 'password',
    label: label,
    required: pw_required,
    autocomplete: pw_autocomplete,
    minlength: pw_min,
    autofocus: pw_autofocus,
    helper: typeof helper !== 'undefined' ? helper : null,
    error: typeof error !== 'undefined' ? error : null,
    showHideToggle: true
  }) %>
  <ul class="password-rules" aria-live="polite">
    <li class="password-rules__item" data-rule="length">
      <span class="password-rules__icon" aria-hidden="true"></span>
      <span class="password-rules__text">At least <%= pw_min %> characters</span>
      <span class="visually-hidden" data-rule-status>not met</span>
    </li>
  </ul>
  <div class="password-strength" role="status" aria-live="polite">
    <div class="password-strength__track" aria-hidden="true">
      <div class="password-strength__fill" data-strength-fill></div>
    </div>
    <span class="password-strength__label" data-strength-label>Enter a password</span>
  </div>
  <% if (pw_with_confirm) { %>
    <%- include('./_input', {
      name: name + '_confirm',
      type: 'password',
      label: pw_confirm_label,
      required: pw_required,
      autocomplete: 'new-password',
      minlength: pw_min,
      showHideToggle: true
    }) %>
    <div class="password-match" role="status" aria-live="polite" data-password-match>
      <span class="password-match__icon" aria-hidden="true"></span>
      <span class="password-match__text" data-password-match-text>Re-enter the password to confirm</span>
    </div>
  <% } %>
</div>
<script nonce="<%= nonce %>">
  // The init-once guard is intentional: each _password partial emits its
  // own <script> but the bound init() finds ALL [data-password-field]
  // elements on the page in one pass, so the second/third invocation is
  // a no-op. Do not move this script per-instance — it's a layout-level
  // initializer that happens to live with the partial for portability.
  (function () {
    if (window.__pwMeterInit) return;
    window.__pwMeterInit = true;
    var LABELS = ['Enter a password', 'Weak', 'Fair', 'Good', 'Strong'];
    function score(pw) {
      if (!pw) return 0;
      var len = pw.length;
      if (len < 8) return 1;
      var classes = 0;
      if (/[a-z]/.test(pw)) classes++;
      if (/[A-Z]/.test(pw)) classes++;
      if (/[0-9]/.test(pw)) classes++;
      if (/[^A-Za-z0-9]/.test(pw)) classes++;
      if (len >= 16 && classes >= 3) return 4;
      if (len >= 12 && classes >= 3) return 3;
      if (len >= 12 && classes >= 2) return 2;
      return 1;
    }
    function bind(field) {
      if (field.__pwBound) return;
      field.__pwBound = true;
      var min = parseInt(field.getAttribute('data-min-length'), 10) || 12;
      // The first password input is the primary; the second (if any) is
      // the confirm. _input wraps inputs in <label class="input-row">,
      // and the show/hide toggle creates a sibling button — query for
      // the actual password inputs only.
      var inputs = field.querySelectorAll('input[type="password"], input[type="text"][data-pw-input]');
      var passwordInputs = [];
      field.querySelectorAll('input').forEach(function (i) {
        var t = i.getAttribute('type');
        if (t === 'password' || (t === 'text' && i.getAttribute('autocomplete') === 'new-password')) {
          passwordInputs.push(i);
        }
      });
      var input = passwordInputs[0];
      var confirm = field.getAttribute('data-with-confirm') === 'true' ? passwordInputs[1] : null;
      var rule = field.querySelector('[data-rule="length"]');
      var ruleStatus = field.querySelector('[data-rule-status]');
      var fill = field.querySelector('[data-strength-fill]');
      var label = field.querySelector('[data-strength-label]');
      var matchWrap = field.querySelector('[data-password-match]');
      var matchText = field.querySelector('[data-password-match-text]');
      if (!input || !rule || !fill || !label) return;

      // Disable the closest form's submit until match is satisfied. Only
      // engage when withConfirm is on; absence keeps single-field forms
      // unchanged.
      var form = input.closest('form');
      var submitButton = form ? form.querySelector('button[type="submit"], input[type="submit"]') : null;

      function updateStrength() {
        var pw = input.value || '';
        var met = pw.length >= min;
        if (met) rule.setAttribute('data-met', 'true');
        else rule.removeAttribute('data-met');
        if (ruleStatus) ruleStatus.textContent = met ? 'met' : 'not met';
        var s = score(pw);
        fill.setAttribute('data-strength', String(s));
        label.textContent = LABELS[s];
      }

      function updateMatch() {
        if (!confirm || !matchWrap || !matchText) return;
        var a = input.value || '';
        var b = confirm.value || '';
        if (b.length === 0) {
          matchWrap.removeAttribute('data-match');
          matchText.textContent = 'Re-enter the password to confirm';
          if (submitButton) submitButton.disabled = false;
          return;
        }
        if (a === b) {
          matchWrap.setAttribute('data-match', 'true');
          matchText.textContent = 'Passwords match';
          if (submitButton) submitButton.disabled = false;
        } else {
          matchWrap.setAttribute('data-match', 'false');
          matchText.textContent = 'Passwords do not match yet';
          if (submitButton) submitButton.disabled = true;
        }
      }

      function update() { updateStrength(); updateMatch(); }
      input.addEventListener('input', update);
      if (confirm) confirm.addEventListener('input', update);
      update();
    }
    function init() {
      document.querySelectorAll('[data-password-field]').forEach(bind);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
