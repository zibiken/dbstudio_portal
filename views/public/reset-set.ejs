<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<form method="post" action="<%= action %>" autocomplete="off" class="form-stack">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <%- include('../components/_password', {
    name: 'password', label: 'New password',
    required: true, minlength: 12, autocomplete: 'new-password',
    helper: 'Screened against the Have I Been Pwned breach corpus.',
    withConfirm: true, confirmLabel: 'Confirm new password',
    nonce: nonce
  }) %>

  <fieldset class="fieldset-stack">
    <legend class="eyebrow">Confirm with your authenticator</legend>
    <p>Enter a 6-digit code from your existing authenticator entry. If you've lost the device, enter one of your unused backup codes instead.</p>
    <%- include('../components/_input', {
      name: 'totp_code', type: 'text', label: '6-digit code',
      inputmode: 'numeric', pattern: '[0-9]{6}', maxlength: 6,
      autocomplete: 'one-time-code'
    }) %>
    <%- include('../components/_input', {
      name: 'backup_code', type: 'text', label: 'Or unconsumed backup code',
      pattern: '[A-HJ-NP-Z2-9]{5}-[A-HJ-NP-Z2-9]{5}', maxlength: 11,
      autocomplete: 'off',
      helper: 'Format: NNNNN-NNNNN.'
    }) %>
  </fieldset>

  <div class="form-actions">
    <%- include('../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Set new password' }) %>
  </div>
</form>
