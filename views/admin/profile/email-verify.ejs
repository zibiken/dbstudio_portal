<section class="admin-profile">
  <header class="admin-section-header">
    <h1>Confirm new email address</h1>
  </header>
  <article class="admin-card">
    <p>You're about to change the email on your DB Studio admin account to the address you used to open this link.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="form-error" role="alert"><%= error %></p>
    <% } %>
    <form method="post" action="/admin/profile/email/verify/<%= token %>" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit">Confirm change</button>
      <a href="/admin/profile" class="cancel-link">Cancel</a>
    </form>
  </article>
</section>
