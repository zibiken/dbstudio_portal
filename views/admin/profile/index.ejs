<section class="admin-profile">
  <header class="admin-section-header">
    <h1>Profile</h1>
    <p class="subtitle">Your admin account.</p>
  </header>

  <article class="admin-card">
    <h2>Display name</h2>
    <% if (typeof nameError !== 'undefined' && nameError) { %>
      <p class="form-error" role="alert"><%= nameError %></p>
    <% } %>
    <form method="post" action="/admin/profile/name" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="profile-name">Name</label>
      <input id="profile-name" name="name" type="text" required maxlength="256"
             value="<%= typeof nameDraft !== 'undefined' ? nameDraft : profile.name %>"
             autocomplete="name">
      <button type="submit">Save name</button>
    </form>
  </article>

  <article class="admin-card">
    <h2>Email</h2>
    <dl class="admin-fields">
      <dt>Current address</dt><dd><%= profile.email %></dd>
    </dl>
    <% if (inflight) { %>
      <p class="muted">A verification email has been sent to <strong><%= inflight.new_email %></strong>.
        The link expires on <%= euDateTime(inflight.verify_expires_at) %>.
        Submitting another new address cancels this request.</p>
    <% } %>
    <% if (typeof emailError !== 'undefined' && emailError) { %>
      <p class="form-error" role="alert"><%= emailError %></p>
    <% } %>
    <form method="post" action="/admin/profile/email" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="new-email">New email</label>
      <input id="new-email" name="new_email" type="email" required maxlength="320"
             value="<%= typeof emailDraft !== 'undefined' ? emailDraft : '' %>"
             autocomplete="email">
      <button type="submit">Send verification link</button>
    </form>
  </article>

  <article class="admin-card">
    <h2>Password</h2>
    <p class="muted">Changing your password signs out every other browser. The current
      session stays alive so you don't get bounced mid-form.</p>
    <% if (typeof passwordError !== 'undefined' && passwordError) { %>
      <p class="form-error" role="alert"><%= passwordError %></p>
    <% } %>
    <form method="post" action="/admin/profile/password" class="admin-form" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="current-password">Current password</label>
      <input id="current-password" name="current_password" type="password" required autocomplete="current-password">
      <label for="new-password">New password</label>
      <input id="new-password" name="new_password" type="password" required autocomplete="new-password" minlength="12">
      <p class="muted">Minimum 12 characters. We screen new passwords against the
        Have I Been Pwned breach corpus.</p>
      <button type="submit">Change password</button>
    </form>
  </article>

  <article class="admin-card">
    <h2>Two-factor authentication</h2>
    <p><a href="/admin/profile/2fa">Regenerate TOTP secret →</a></p>
  </article>

  <article class="admin-card">
    <h2>Backup codes</h2>
    <p><a href="/admin/profile/backup-codes">Regenerate backup codes →</a></p>
  </article>

  <article class="admin-card">
    <h2>Active sessions</h2>
    <p><a href="/admin/profile/sessions">Manage active sessions →</a></p>
  </article>
</section>
