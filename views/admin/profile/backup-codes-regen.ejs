<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · PROFILE',
  title: 'Regenerate backup codes',
  subtitle: 'After regenerating, your old codes stop working immediately.'
}) %>

<div class="card">
  <h2 class="card__title">Prove it's you</h2>
  <p class="card__subtitle">Enter either a current TOTP code OR an unconsumed backup code.</p>
  <% if (typeof error !== 'undefined' && error) { %>
    <%- include('../../components/_alert', { variant: 'error', body: error }) %>
  <% } %>
  <form method="post" action="/admin/profile/backup-codes" class="form-stack" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <%- include('../../components/_input', {
      name: 'totp_code', type: 'text', label: '6-digit TOTP code',
      inputmode: 'numeric', pattern: '[0-9]{6}', maxlength: 6,
      autocomplete: 'one-time-code',
      helper: 'From your authenticator app.'
    }) %>
    <%- include('../../components/_input', {
      name: 'backup_code', type: 'text', label: 'Or unconsumed backup code',
      pattern: '[A-HJ-NP-Z2-9]{5}-[A-HJ-NP-Z2-9]{5}', maxlength: 11,
      autocomplete: 'off',
      helper: 'Format: NNNNN-NNNNN.'
    }) %>
    <div class="form-actions">
      <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Generate new codes' }) %>
      <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/admin/profile', label: 'Cancel' }) %>
    </div>
  </form>
</div>
