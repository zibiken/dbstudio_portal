<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN',
  title: 'Audit log',
  subtitle: 'Append-only stream of every audit-relevant event. Filter, browse, or export to CSV.'
}) %>

<div class="card">
  <h2 class="card__title">Filter</h2>
  <form method="get" action="/admin/audit" class="activity-filter">
    <div class="activity-filter__field">
      <label for="audit-filter">Section</label>
      <select id="audit-filter" name="filter" class="cr-fields__input">
        <% filterOptions.forEach(function(opt) { %>
          <option value="<%= opt.value %>" <%= opt.value === filter ? 'selected' : '' %>><%= opt.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="activity-filter__field">
      <label for="audit-actor">Actor</label>
      <select id="audit-actor" name="actor" class="cr-fields__input">
        <% actorOptions.forEach(function(opt) { %>
          <option value="<%= opt.value %>" <%= opt.value === actorType ? 'selected' : '' %>><%= opt.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="activity-filter__field">
      <label for="audit-since">From</label>
      <input id="audit-since" name="since" type="date" value="<%= since %>" class="cr-fields__input">
    </div>
    <div class="activity-filter__field">
      <label for="audit-until">To</label>
      <input id="audit-until" name="until" type="date" value="<%= until %>" class="cr-fields__input">
    </div>
    <div class="activity-filter__field">
      <label for="audit-limit">Show</label>
      <input id="audit-limit" name="limit" type="number" min="1" max="500" value="<%= limit %>" class="cr-fields__input">
    </div>
    <div class="activity-filter__actions">
      <%- include('../../components/_button', { variant: 'primary',   size: 'md', type: 'submit', label: 'Apply' }) %>
      <%- include('../../components/_button', { variant: 'ghost',     size: 'md', href: '/admin/audit', label: 'Reset' }) %>
      <%- include('../../components/_button', { variant: 'secondary', size: 'md', href: '/admin/audit-export.csv?' + currentQueryString, label: 'Export CSV' }) %>
    </div>
  </form>
</div>

<% if (events && events.length) { %>
  <div class="card">
    <h2 class="card__title"><%= events.length %> <%= events.length === 1 ? 'event' : 'events' %></h2>
    <div class="table-wrap">
      <table class="data-table data-table--medium">
        <thead>
          <tr>
            <th scope="col" class="data-table__th data-table__th--left">When</th>
            <th scope="col" class="data-table__th data-table__th--left">Actor</th>
            <th scope="col" class="data-table__th data-table__th--left">Action</th>
            <th scope="col" class="data-table__th data-table__th--left">Target</th>
            <th scope="col" class="data-table__th data-table__th--left">Customer-visible</th>
            <th scope="col" class="data-table__th data-table__th--left">IP</th>
            <th scope="col" class="data-table__th data-table__th--left">Metadata</th>
          </tr>
        </thead>
        <tbody>
          <% events.forEach(function(e) { %>
            <tr>
              <td class="data-table__td data-table__td--left">
                <time datetime="<%= e.ts %>"><%= euDateTime(e.ts) %></time>
              </td>
              <td class="data-table__td data-table__td--left">
                <span class="status-pill status-pill--<%= e.actor_type === 'admin' ? 'active' : (e.actor_type === 'customer' ? 'pending' : 'archived') %>"><%= e.actor_type %></span>
                <% if (e.actor_email) { %>
                  <%- include('../../components/_user-mention', { name: e.actor_name, email: e.actor_email }) %>
                <% } %>
              </td>
              <td class="data-table__td data-table__td--left"><code><%= e.action %></code></td>
              <td class="data-table__td data-table__td--left">
                <% if (e.target_type) { %>
                  <%= e.target_type %><% if (e.target_id) { %><br><code class="muted"><%= e.target_id %></code><% } %>
                <% } else { %>
                  <span class="muted">—</span>
                <% } %>
              </td>
              <td class="data-table__td data-table__td--left">
                <% if (e.visible_to_customer) { %>
                  <span class="status-pill status-pill--paid">yes</span>
                <% } else { %>
                  <span class="status-pill status-pill--archived">no</span>
                <% } %>
              </td>
              <td class="data-table__td data-table__td--left">
                <% if (e.ip) { %><code class="muted"><%= e.ip %></code><% } else { %><span class="muted">—</span><% } %>
              </td>
              <td class="data-table__td data-table__td--left">
                <% if (e.metadata && Object.keys(e.metadata).length > 0) { %>
                  <code class="audit-meta-json"><%= JSON.stringify(e.metadata) %></code>
                <% } else { %>
                  <span class="muted">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (nextCursor) {
         const qs = currentQueryString
           .split('&')
           .filter(function(p) { return p && !p.startsWith('cursor='); })
           .concat(['cursor=' + encodeURIComponent(nextCursor)])
           .join('&');
    %>
      <div class="form-actions">
        <%- include('../../components/_button', { variant: 'ghost', size: 'md', href: '/admin/audit?' + qs, label: 'Older →' }) %>
      </div>
    <% } %>
  </div>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No events match these filters',
    lead: 'Try widening the date range, switching the actor or section filter, or resetting to the defaults.',
    secondaryHref: '/admin/audit',
    secondaryLabel: 'Reset filters'
  }) %>
<% } %>
