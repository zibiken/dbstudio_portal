<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'Invoice ' + row.invoice_number,
  subtitle: customer.razon_social,
  actions: '<span class="status-pill status-pill--' + (row.overdue && row.status === 'open' ? 'overdue' : row.status) + '">' + (row.overdue && row.status === 'open' ? 'overdue' : row.status) + '</span>'
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'invoices' }) %>

<% if (typeof flash !== 'undefined' && flash) { %>
  <%- include('../../components/_alert', { variant: 'info', body: flash }) %>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<div class="card">
  <h2 class="card__title">Invoice details</h2>
  <dl class="kv">
    <dt>Customer</dt> <dd><a href="/admin/customers/<%= row.customer_id %>"><%= customer.razon_social %></a></dd>
    <dt>Amount</dt>   <dd><%= (Number(row.amount_cents)/100).toFixed(2) %> <%= row.currency %></dd>
    <dt>Issued</dt>   <dd><%= euDate(row.issued_on) %></dd>
    <dt>Due</dt>      <dd><%= euDate(row.due_on) %></dd>
    <dt>Status</dt>   <dd><span class="status-pill status-pill--<%= row.overdue && row.status === 'open' ? 'overdue' : row.status %>"><%= row.overdue && row.status === 'open' ? 'overdue' : row.status %></span></dd>
    <dt>Notes</dt>    <dd><%= row.notes || '—' %></dd>
    <dt>PDF</dt>      <dd><a href="/admin/documents/<%= row.document_id %>/download">Download invoice PDF</a></dd>
  </dl>
</div>

<% if (nextStatuses.length > 0) { %>
  <section class="status-actions">
    <h2>Status transitions</h2>
    <div class="form-actions">
      <% for (const next of nextStatuses) { %>
        <form method="post" action="/admin/invoices/<%= row.id %>/status" class="form-inline-action">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="status" value="<%= next %>">
          <%- include('../../components/_button', { variant: 'secondary', size: 'sm', type: 'submit', label: 'Mark ' + next }) %>
        </form>
      <% } %>
    </div>
  </section>
<% } %>

<%# Phase B — payments ledger panel. Read-only listing on top, record-form below. %>
<div class="card">
  <h2 class="card__title">Payments</h2>
  <% if (payments && payments.length) { %>
    <div class="table-wrap">
      <table class="data-table data-table--medium">
        <thead>
          <tr>
            <th class="data-table__th data-table__th--left">Date</th>
            <th class="data-table__th data-table__th--right">Amount</th>
            <th class="data-table__th data-table__th--left">Note</th>
            <th class="data-table__th data-table__th--right"></th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(function(p) { %>
            <tr>
              <td class="data-table__td data-table__td--left"><%= euDate(p.paid_on) %></td>
              <td class="data-table__td data-table__td--right">€<%= (Number(p.amount_cents)/100).toFixed(2) %></td>
              <td class="data-table__td data-table__td--left"><%= p.note || '' %></td>
              <td class="data-table__td data-table__td--right">
                <form method="post" action="/admin/invoices/<%= row.id %>/payments/<%= p.id %>/delete" class="form-inline-action">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <%- include('../../components/_button', { variant: 'ghost', size: 'sm', type: 'submit', label: 'Delete' }) %>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p>Paid €<%= (Number(paidCents)/100).toFixed(2) %> of €<%= (Number(row.amount_cents)/100).toFixed(2) %><% if (Number(paidCents) < Number(row.amount_cents)) { %> &middot; outstanding €<%= ((Number(row.amount_cents) - Number(paidCents))/100).toFixed(2) %><% } %>.</p>
  <% } else { %>
    <p class="muted">No payments recorded yet.</p>
  <% } %>

  <% if (Number(paidCents) < Number(row.amount_cents)) { %>
    <h3>Record a payment</h3>
    <form method="post" action="/admin/invoices/<%= row.id %>/payments" class="form-stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <%- include('../../components/_input', { name: 'amount_eur',  type: 'number', label: 'Amount (€)', required: true, inputmode: 'decimal', step: '0.01', min: '0', placeholder: '12.50', value: '' }) %>
      <%- include('../../components/_input', { name: 'paid_on',      type: 'date',   label: 'Paid on',        required: true, value: '' }) %>
      <div class="input-field">
        <label class="input-field__label" for="pay_note">Note (optional)</label>
        <div class="input-field__control"><textarea id="pay_note" name="note" rows="2"></textarea></div>
      </div>
      <div class="form-actions">
        <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Record payment' }) %>
      </div>
    </form>
  <% } %>
</div>
