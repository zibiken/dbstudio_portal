<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'Generate NDA draft',
  subtitle: customer.razon_social
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'ndas' }) %>

<% if (error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<% if (missingFields.length > 0) { %>
  <%- include('../../components/_alert', { variant: 'warn', body: 'Customer profile is missing fields required by the NDA template: <strong>' + missingFields.join(', ') + '</strong>. <a href="/admin/customers/' + customer.id + '/edit">Edit profile →</a>' }) %>
<% } %>

<div class="card">
  <p>The draft is rendered server-side from <code>templates/nda.html</code> and stored as <code>category='nda-draft'</code>. Drafts are <strong>admin-only</strong> — the customer will only see the signed copy + audit-trail once you upload them after signing on your secure platform.</p>
  <p>Place of signature: <strong>Adeje</strong> (fixed). Date of signature: <strong><%= euDate(new Date()) %></strong> (today).</p>
</div>

<% if (projects.length === 0) { %>
  <%- include('../../components/_alert', { variant: 'info', body: 'No projects yet for this customer. <a href="/admin/customers/' + customer.id + '/projects/new">Create a project</a> first.' }) %>
<% } else { %>
  <form method="post" action="/admin/customers/<%= customer.id %>/ndas" autocomplete="off" class="form-stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="input-field">
      <label class="input-field__label" for="nda_project">Project</label>
      <div class="input-field__control">
        <select id="nda_project" name="project_id" required>
          <option value="">—</option>
          <% for (const p of projects) { %>
            <option value="<%= p.id %>"><%= p.name %></option>
          <% } %>
        </select>
      </div>
    </div>

    <div class="form-actions">
      <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Generate draft PDF', disabled: missingFields.length > 0 }) %>
      <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/admin/customers/' + customer.id + '/ndas', label: 'Cancel' }) %>
    </div>
  </form>
<% } %>
