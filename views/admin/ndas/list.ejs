<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'NDAs',
  subtitle: customer.razon_social,
  actions: '<a class="btn btn--primary btn--md" href="/admin/customers/' + customer.id + '/ndas/new">+ Generate draft</a>'
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'ndas' }) %>

<%
  function flag(b) { return b ? '<span class="status-pill status-pill--active">yes</span>' : '<span class="status-pill">—</span>'; }
  var tableRows = (rows || []).map(function(r) {
    return { cells: [
      r.project_name || '—',
      euDateTime(r.generated_at),
      '<code>' + (r.template_version_sha || '').slice(0, 8) + '</code>',
      flag(true),
      flag(r.signed_document_id),
      flag(r.audit_document_id),
      '<a class="btn btn--ghost btn--sm" href="/admin/ndas/' + r.id + '">Open →</a>'
    ]};
  });
%>
<%- include('../../components/_table', {
  density: 'medium',
  columns: [
    { label: 'Project',           align: 'left' },
    { label: 'Generated',         align: 'left' },
    { label: 'Template sha (8)',  align: 'left' },
    { label: 'Draft',             align: 'left' },
    { label: 'Signed',            align: 'left' },
    { label: 'Audit-trail',       align: 'left' },
    { label: '',                  align: 'right' }
  ],
  rows: tableRows,
  emptyState: 'No NDAs generated for this customer yet.'
}) %>
