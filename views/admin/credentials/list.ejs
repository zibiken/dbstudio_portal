<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'Credentials',
  subtitle: customer.razon_social
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'credentials' }) %>

<%- include('../../components/_alert', {
  variant: 'info',
  body: 'Click a label to open a credential\'s detail page. Each reveal requires a fresh 2FA step-up and writes a customer-visible audit row + digest event. To request a new credential, use the <a href="/admin/customers/' + customer.id + '/credential-requests/new">credential requests</a> tab.'
}) %>

<% if (rows && rows.length) { %>
  <%
    function originPill(origin) {
      var key = origin === 'admin' ? 'pending' : 'active';
      return '<span class="status-pill status-pill--' + key + '">' + (origin === 'admin' ? 'created by admin' : 'added by customer') + '</span>';
    }
    function freshnessPill(needsUpdate) {
      if (needsUpdate) return '<span class="status-pill status-pill--overdue">needs update</span>';
      return '<span class="status-pill status-pill--paid">current</span>';
    }
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function(ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
      });
    }
    var tableRows = rows.map(function(c) {
      var detailHref = '/admin/customers/' + customer.id + '/credentials/' + c.id;
      var labelLink = '<a href="' + escapeHtml(detailHref) + '">' + escapeHtml(c.label) + '</a>';
      return { cells: [
        labelLink,
        escapeHtml(c.provider),
        originPill(c.created_by),
        freshnessPill(c.needs_update),
        euDateTime(c.created_at),
        euDateTime(c.updated_at)
      ]};
    });
  %>
  <%- include('../../components/_table', {
    density: 'medium',
    columns: [
      { label: 'Label',     align: 'left' },
      { label: 'Provider',  align: 'left' },
      { label: 'Origin',    align: 'left' },
      { label: 'Freshness', align: 'left' },
      { label: 'Created',   align: 'left' },
      { label: 'Updated',   align: 'left' }
    ],
    rows: tableRows
  }) %>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No credentials on file for ' + customer.razon_social,
    lead: 'Customers add credentials directly from their own portal — admins request them but do not enter values. Open a credential request to ask this customer for a specific provider; they fill in the values, encrypted with their own vault key.',
    ctaHref: '/admin/customers/' + customer.id + '/credential-requests/new',
    ctaLabel: 'Open a credential request',
    secondaryHref: '/admin/customers/' + customer.id + '/credential-requests',
    secondaryLabel: 'See existing requests'
  }) %>
<% } %>
