<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'New project',
  subtitle: customer.razon_social
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'projects' }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<form method="post" action="/admin/customers/<%= customer.id %>/projects" autocomplete="off" class="form-stack">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <%- include('../../components/_input', { name: 'name', type: 'text', label: 'Name', required: true, maxlength: 200, value: form ? (form.name || '') : '' }) %>

  <div class="input-field">
    <label class="input-field__label" for="proj_objeto">Objeto del proyecto</label>
    <div class="input-field__control">
      <textarea id="proj_objeto" name="objeto_proyecto" required maxlength="2000" rows="4"><%= form ? (form.objeto_proyecto || '') : '' %></textarea>
    </div>
    <p class="input-field__helper">Used as the legal subject of the NDA in M8.</p>
  </div>

  <div class="form-actions">
    <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Create project' }) %>
    <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/admin/customers/' + customer.id + '/projects', label: 'Cancel' }) %>
  </div>
</form>
