<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'Credential requests',
  subtitle: customer.razon_social,
  actions: '<a class="btn btn--primary btn--md" href="/admin/customers/' + customer.id + '/credential-requests/new">+ New request</a>'
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: 'credential-requests' }) %>

<%
  function pillFor(s) {
    var key = s === 'open' ? 'pending' : (s === 'fulfilled' ? 'fulfilled' : (s === 'cancelled' ? 'archived' : (s === 'not_applicable' ? 'void' : 'pending')));
    return '<span class="status-pill status-pill--' + key + '">' + s + '</span>';
  }
  var tableRows = (requests || []).map(function(r) {
    return { cells: [
      r.provider,
      pillFor(r.status),
      String((r.fields || []).length),
      euDateTime(r.created_at),
      '<a class="btn btn--ghost btn--sm" href="/admin/customers/' + customer.id + '/credential-requests/' + r.id + '">Open →</a>'
    ]};
  });
%>
<%- include('../../components/_table', {
  density: 'dense',
  columns: [
    { label: 'Provider', align: 'left' },
    { label: 'Status',   align: 'left' },
    { label: 'Fields',   align: 'left' },
    { label: 'Created',  align: 'left' },
    { label: '',         align: 'right' }
  ],
  rows: tableRows,
  emptyState: 'No credential requests yet.'
}) %>
