<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'Customer created'
}) %>

<%- include('../../components/_alert', { variant: 'success', body: '<strong>' + customer.razon_social + '</strong> is set up. <strong>' + primaryUser.name + '</strong> &lt;' + primaryUser.email + '&gt; will receive the welcome email shortly.' }) %>

<div class="card">
  <p class="eyebrow">Belt-and-braces invite link</p>
  <h2 class="card__title">Share this link if the email never lands</h2>
  <p>It expires on <strong><%= euDateTime(invite.expiresAt) %></strong>. Shown <strong>once</strong> on this page — after you leave it, the only way to reissue is to trigger a password reset for the user.</p>
  <p><code class="qr-block__secret"><%= invite.url %></code></p>
</div>

<div class="form-actions">
  <%- include('../../components/_button', { variant: 'primary', size: 'md', href: '/admin/customers/' + customer.id, label: 'Open customer →' }) %>
  <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/admin/customers', label: 'Back to list' }) %>
</div>
