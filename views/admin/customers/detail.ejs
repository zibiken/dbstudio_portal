<section class="admin-customer-detail">
  <header class="admin-section-header">
    <h1><%= customer.razon_social %></h1>
    <span class="status status-<%= customer.status %>"><%= customer.status %></span>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="error" role="alert"><%= error %></p>
  <% } %>

  <% if (customer.status !== 'archived') { %>
    <div class="admin-actions">
      <% if (customer.status === 'active') { %>
        <form method="post" action="/admin/customers/<%= customer.id %>/suspend">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-warning">Suspend</button>
        </form>
      <% } else if (customer.status === 'suspended') { %>
        <form method="post" action="/admin/customers/<%= customer.id %>/reactivate">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-primary">Reactivate</button>
        </form>
      <% } %>
      <form method="post" action="/admin/customers/<%= customer.id %>/archive"
            onsubmit="return confirm('Archive this customer? This cannot be undone from the UI.');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-danger">Archive</button>
      </form>
    </div>
  <% } %>

  <p><a class="btn btn-secondary" href="/admin/customers/<%= customer.id %>/edit">Edit profile</a></p>

  <dl class="admin-fields">
    <dt>NIF</dt><dd><%= customer.nif ?? '—' %></dd>
    <dt>Domicilio</dt><dd><%= customer.domicilio ?? '—' %></dd>
    <dt>Representante (nombre)</dt><dd><%= customer.representante_nombre ?? '—' %></dd>
    <dt>Representante (DNI)</dt><dd><%= customer.representante_dni ?? '—' %></dd>
    <dt>Representante (cargo)</dt><dd><%= customer.representante_cargo ?? '—' %></dd>
    <dt>Created</dt><dd><%= euDateTime(customer.created_at) %></dd>
    <dt>Updated</dt><dd><%= euDateTime(customer.updated_at) %></dd>
  </dl>

  <h2>Users</h2>
  <% if (users.length === 0) { %>
    <p class="empty">No users on this customer yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Status</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((u) => { %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td>
              <% if (u.invite_consumed_at) { %>
                <span class="status status-active">active</span>
              <% } else if (new Date(u.invite_expires_at).getTime() <= Date.now()) { %>
                <span class="status status-expired">invite expired</span>
              <% } else { %>
                <span class="status status-pending">invite pending</span>
              <% } %>
            </td>
            <td><%= euDateTime(u.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <p class="admin-back">
    <a href="/admin/customers">← Back to customer list</a>
  </p>
</section>
