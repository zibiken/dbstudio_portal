<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: customer.razon_social,
  subtitle: customer.nif ? ('Tax ID ' + customer.nif) : null
}) %>

<%- include('../../components/_admin-customer-tabs', { customerId: customer.id, active: typeof activeTab !== 'undefined' ? activeTab : 'detail' }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<div class="card">
  <div class="card__title-row">
    <h2 class="card__title">Company details</h2>
    <span class="status-pill status-pill--<%= customer.status %>"><%= customer.status %></span>
  </div>
  <dl class="kv">
    <dt>Tax ID</dt>            <dd><%= customer.nif || '—' %></dd>
    <dt>Registered address</dt><dd><%= customer.domicilio || '—' %></dd>
    <dt>Representative name</dt><dd><%= customer.representante_nombre || '—' %></dd>
    <dt>Representative ID</dt> <dd><%= customer.representante_dni || '—' %></dd>
    <dt>Representative title</dt><dd><%= customer.representante_cargo || '—' %></dd>
    <dt>Created</dt>           <dd><%= euDateTime(customer.created_at) %></dd>
    <dt>Updated</dt>           <dd><%= euDateTime(customer.updated_at) %></dd>
  </dl>
  <% if (customer.status !== 'archived') { %>
    <div class="form-actions">
      <%- include('../../components/_button', { variant: 'secondary', size: 'sm', href: '/admin/customers/' + customer.id + '/edit', label: 'Edit details' }) %>
    </div>
  <% } %>
</div>

<div class="card">
  <h2 class="card__title">Users</h2>
  <p class="card__subtitle">People who can sign in to this company's portal.</p>
  <%
    var userRows = (users || []).map(function(u) {
      var status, pill;
      if (u.invite_consumed_at) { status = 'active'; pill = 'active'; }
      else if (new Date(u.invite_expires_at).getTime() <= Date.now()) { status = 'invite expired'; pill = 'expired'; }
      else { status = 'invite pending'; pill = 'pending'; }
      return { cells: [
        u.name,
        u.email,
        '<span class="status-pill status-pill--' + pill + '">' + status + '</span>',
        euDateTime(u.created_at)
      ]};
    });
  %>
  <%- include('../../components/_table', {
    density: 'medium',
    columns: [
      { label: 'Name',    align: 'left' },
      { label: 'Email',   align: 'left' },
      { label: 'Status',  align: 'left' },
      { label: 'Created', align: 'left' }
    ],
    rows: userRows,
    emptyState: 'No users on this customer yet.'
  }) %>
</div>

<% if (customer.status !== 'archived') { %>
  <div class="card card--danger">
    <h2 class="card__title">Customer status</h2>
    <p class="card__subtitle">Currently <strong><%= customer.status %></strong>. Suspending blocks the customer's portal access; archive is permanent.</p>
    <div class="form-actions">
      <% if (customer.status === 'active') { %>
        <form method="post" action="/admin/customers/<%= customer.id %>/suspend" class="form-inline-action">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <%- include('../../components/_button', { variant: 'secondary', size: 'sm', type: 'submit', label: 'Suspend' }) %>
        </form>
      <% } else if (customer.status === 'suspended') { %>
        <form method="post" action="/admin/customers/<%= customer.id %>/reactivate" class="form-inline-action">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <%- include('../../components/_button', { variant: 'primary', size: 'sm', type: 'submit', label: 'Reactivate' }) %>
        </form>
      <% } %>
      <form method="post" action="/admin/customers/<%= customer.id %>/archive" class="form-inline-action"
            onsubmit="return confirm('Archive this customer? This cannot be undone from the UI.');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <%- include('../../components/_button', { variant: 'danger', size: 'sm', type: 'submit', label: 'Archive' }) %>
      </form>
    </div>
  </div>
<% } %>
