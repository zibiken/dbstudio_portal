<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN',
  title: 'Customers',
  subtitle: total === 1 ? 'One customer on file.' : (total === 0 ? null : total + ' customers on file.')
}) %>

<%- include('../../components/_list-toolbar', {
  action: '/admin/customers',
  q: q,
  total: total,
  totalLabel: 'customer',
  placeholder: 'Search by company name, NIF, contact email, or contact name…',
  ctaHref: '/admin/customers/new',
  ctaLabel: 'New customer'
}) %>

<% if (rows && rows.length) { %>
  <div class="table-wrap">
    <table class="data-table data-table--medium">
      <thead>
        <tr>
          <th scope="col" class="data-table__th data-table__th--left">Company name</th>
          <th scope="col" class="data-table__th data-table__th--left">Tax ID</th>
          <th scope="col" class="data-table__th data-table__th--left">Primary contact</th>
          <th scope="col" class="data-table__th data-table__th--left">Status</th>
          <th scope="col" class="data-table__th data-table__th--left">Created</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(c) { %>
          <tr>
            <td class="data-table__td data-table__td--left">
              <a href="/admin/customers/<%= c.id %>"><%= c.razon_social %></a>
            </td>
            <td class="data-table__td data-table__td--left">
              <% if (c.nif) { %><%= c.nif %><% } else { %><span class="muted">—</span><% } %>
            </td>
            <td class="data-table__td data-table__td--left">
              <%- include('../../components/_user-mention', { name: c.primary_contact_name, email: c.primary_contact_email }) %>
            </td>
            <td class="data-table__td data-table__td--left">
              <span class="status-pill status-pill--<%= c.status %>"><%= c.status %></span>
            </td>
            <td class="data-table__td data-table__td--left">
              <time datetime="<%= new Date(c.created_at).toISOString() %>"><%= euDate(c.created_at) %></time>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../../components/_pagination', { page: page, totalPages: totalPages, q: q, perPage: perPage, qs: qs }) %>
<% } else if (q) { %>
  <%- include('../../components/_empty-state', {
    headline: 'No customers match this search',
    lead: 'Try a different spelling, or clear the search to see every customer on file.',
    ctaHref: '/admin/customers',
    ctaLabel: 'Clear search'
  }) %>
<% } else { %>
  <%- include('../../components/_empty-state', {
    headline: 'No customers yet',
    lead: 'Customers added here are invited by secure email — they receive a single-use link to set their password and register an authenticator app.',
    ctaHref: '/admin/customers/new',
    ctaLabel: 'Add the first customer'
  }) %>
<% } %>
