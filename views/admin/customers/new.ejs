<%- include('../../components/_page-header', {
  eyebrow: 'ADMIN · CUSTOMERS',
  title: 'New customer'
}) %>

<% if (typeof error !== 'undefined' && error) { %>
  <%- include('../../components/_alert', { variant: 'error', body: error }) %>
<% } %>

<form method="post" action="/admin/customers" autocomplete="off" class="form-stack">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <fieldset class="fieldset-stack">
    <legend class="eyebrow">Customer (the company)</legend>
    <%- include('../../components/_input', { name: 'razon_social', type: 'text', label: 'Razón social', required: true, maxlength: 200, value: form ? (form.razon_social || '') : '' }) %>
    <%- include('../../components/_input', { name: 'nif',          type: 'text', label: 'NIF', maxlength: 20, value: form ? (form.nif || '') : '' }) %>
    <%- include('../../components/_input', { name: 'domicilio',    type: 'text', label: 'Domicilio', maxlength: 300, value: form ? (form.domicilio || '') : '' }) %>
  </fieldset>

  <fieldset class="fieldset-stack">
    <legend class="eyebrow">Primary user</legend>
    <p>Receives the welcome email and becomes the customer's first user.</p>
    <%- include('../../components/_input', { name: 'primary_user_name',  type: 'text',  label: 'Name',  required: true, maxlength: 120, value: form ? (form.primary_user_name || '') : '' }) %>
    <%- include('../../components/_input', { name: 'primary_user_email', type: 'email', label: 'Email', required: true, maxlength: 254, autocomplete: 'email', value: form ? (form.primary_user_email || '') : '' }) %>
  </fieldset>

  <div class="form-actions">
    <%- include('../../components/_button', { variant: 'primary', size: 'md', type: 'submit', label: 'Create customer' }) %>
    <%- include('../../components/_button', { variant: 'ghost',   size: 'md', href: '/admin/customers', label: 'Cancel' }) %>
  </div>
</form>
