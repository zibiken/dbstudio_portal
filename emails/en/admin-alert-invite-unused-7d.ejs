<%# subject: Customer invitation unused after 7 days %>
<div style="<%- S.tagline %>">Admin · Invitation reminder</div>
<h1 style="<%- S.h1 %>"><%= customerName %> hasn't accepted yet</h1>
<p style="<%- S.body %>">Hi <%= recipientName %>,</p>
<p style="<%- S.body %>">The portal invitation you sent to <%= customerName %> hasn't been used. It's been seven days.</p>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.metaTable %>">
  <tr>
    <td style="<%- S.metaLabel %>">Customer</td>
    <td style="<%- S.metaValue %>"><%= customerName %></td>
  </tr>
  <tr>
    <td style="<%- S.metaLabel %>">Email</td>
    <td style="<%- S.metaValue %>"><%= customerEmail %></td>
  </tr>
</table>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.ctaWrap %>">
  <tr><td style="<%- S.ctaCell %>"><a href="<%= adminUrl %>" style="<%- S.ctaLink %>">Open customer →</a></td></tr>
</table>
<p style="<%- S.note %>">From the customer page you can resend the invitation, change the recipient, or revoke and reissue.</p>
