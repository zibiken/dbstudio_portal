<%# subject: Reset your DB Studio admin password %>
<div style="<%- S.tagline %>">Admin · Password reset</div>
<h1 style="<%- S.h1 %>">Reset your admin password</h1>
<p style="<%- S.body %>">Hi <%= recipientName %>,</p>
<p style="<%- S.body %>">A password reset has been issued for your DB Studio admin account. Use the link below to choose a new password and re-enrol your second factor.</p>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.ctaWrap %>">
  <tr><td style="<%- S.ctaCell %>"><a href="<%= resetUrl %>" style="<%- S.ctaLink %>">Reset password →</a></td></tr>
</table>
<p style="<%- S.note %>">This link expires on <%= euDate(expiresAt) %>. If you didn't expect this email, contact the operator who manages the portal before clicking — admin resets are issued out-of-band on request.</p>
