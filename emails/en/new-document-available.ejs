<%# subject: New document available in your portal %>
<div style="<%- S.tagline %>">Portal · New document</div>
<h1 style="<%- S.h1 %>"><%= documentName %> is ready</h1>
<p style="<%- S.body %>">Hi <%= recipientName %>,</p>
<p style="<%- S.body %>">DB Studio shared a new document in your portal. Open it to view, download, or comment.</p>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.ctaWrap %>">
  <tr><td style="<%- S.ctaCell %>"><a href="<%= documentUrl %>" style="<%- S.ctaLink %>">View document →</a></td></tr>
</table>
<p style="<%- S.note %>">Documents stay available in your portal for the duration of our engagement.</p>
