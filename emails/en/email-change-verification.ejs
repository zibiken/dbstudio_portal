<%# subject: Verify your new email address %>
<div style="<%- S.tagline %>">Portal · Email verification</div>
<h1 style="<%- S.h1 %>">Confirm your new email address</h1>
<p style="<%- S.body %>">Hi <%= recipientName %>,</p>
<p style="<%- S.body %>">You asked to change the email address on your DB Studio portal account to <strong style="color:#FFFFFF;"><%= newEmail %></strong>. Confirm by clicking below; until then, your old address keeps receiving sign-in notifications.</p>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.ctaWrap %>">
  <tr><td style="<%- S.ctaCell %>"><a href="<%= verifyUrl %>" style="<%- S.ctaLink %>">Confirm new address →</a></td></tr>
</table>
<p style="<%- S.note %>">This link expires on <%= euDate(expiresAt) %>. If you didn't request this change, ignore the email — nothing happens until you confirm.</p>
