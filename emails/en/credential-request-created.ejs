<%# subject: New credential request from a customer %>
<div style="<%- S.tagline %>">Admin · Credential request</div>
<h1 style="<%- S.h1 %>"><%= customerName %> requested credentials</h1>
<p style="<%- S.body %>">Hi <%= recipientName %>,</p>
<p style="<%- S.body %>"><%= customerName %> opened a credential request in the portal. Open it to review the scope and respond.</p>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="<%- S.ctaWrap %>">
  <tr><td style="<%- S.ctaCell %>"><a href="<%= requestUrl %>" style="<%- S.ctaLink %>">Open request →</a></td></tr>
</table>
<p style="<%- S.note %>">Credential entries are encrypted with the customer's per-row key. Decryption only happens when you actively view a row.</p>
